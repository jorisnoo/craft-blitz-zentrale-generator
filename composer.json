{
    "name": "jorisnoo/craft-blitz-zentrale-generator",
    "description": "Blitz cache generator that delegates warming to the Zentrale API.",
    "keywords": [
        "craftcms",
        "blitz",
        "zentrale",
        "cache",
        "warming"
    ],
    "homepage": "https://github.com/jorisnoo/craft-blitz-zentrale-generator",
    "type": "craft-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Joris Noordermeer",
            "email": "contact@noordermeer.ch",
            "homepage": "https://github.com/jorisnoo",
            "role": "Developer"
        }
    ],
    "support": {
        "source": "https://github.com/jorisnoo/craft-blitz-zentrale-generator",
        "issues": "https://github.com/jorisnoo/craft-blitz-zentrale-generator/issues"
    },
    "require": {
        "php": "^8.2",
        "craftcms/cms": "^5.0",
        "putyourlightson/craft-blitz": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "Noo\\CraftBlitzZentraleGenerator\\": "src/"
        }
    },
    "extra": {
        "handle": "blitz-zentrale-generator",
        "name": "Blitz Zentrale Generator",
        "developer": "Joris Noordermeer",
        "developerUrl": "https://github.com/jorisnoo",
        "class": "Noo\\CraftBlitzZentraleGenerator\\Plugin"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
